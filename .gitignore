# ── Dependencies ──────────────────────────────────────────
node_modules/
**/node_modules/

# ── Environment variables (never commit secrets) ──────────
.env
.env.*
!.env.example

# ── Build outputs ─────────────────────────────────────────
dist/
dist-ssr/
build/

# ── Backend: captured screenshots (ephemeral, not source) ─
backend/screenshots/*
!backend/screenshots/.gitkeep

# ── Logs ──────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ── OS & editor clutter ───────────────────────────────────
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?